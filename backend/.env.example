# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ois_user:ois_pass@localhost:5432/ois_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
